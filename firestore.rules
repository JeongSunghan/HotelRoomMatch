rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== Helper Functions ====================
    
    /**
     * 관리자 권한 확인
     * Firebase Auth의 관리자 이메일로 확인
     */
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email != null &&
             request.auth.token.email.matches('.*@admin\\.com$'); // 관리자 이메일 패턴 수정 필요
    }
    
    /**
     * 인증된 사용자 확인
     */
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // ==================== users 컬렉션 ====================
    
    match /users/{userId} {
      // 읽기: 인증된 사용자 (자신 또는 관리자)
      allow read: if isAuthenticated();
      
      // 생성: 관리자만
      allow create: if isAdmin();
      
      // 업데이트: 관리자만
      allow update: if isAdmin();
      
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }
    
    // ==================== userStays 컬렉션 ====================
    
    match /userStays/{stayId} {
      // 읽기: 인증된 사용자 (자신의 userId 또는 관리자)
      allow read: if isAuthenticated() && 
                     (resource.data.userId == request.auth.uid || isAdmin());
      
      // 생성: 인증된 사용자 자신 또는 관리자
      allow create: if isAuthenticated() && 
                       (request.resource.data.userId == request.auth.uid || isAdmin());
      
      // 업데이트: 자신의 데이터 또는 관리자
      allow update: if isAuthenticated() && 
                       (resource.data.userId == request.auth.uid || isAdmin());
      
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }
    
    // ==================== otpRequests 컬렉션 (선택사항) ====================
    
    match /otpRequests/{requestId} {
      // 읽기/쓰기: 서버 사이드에서만 (클라이언트 접근 제한)
      allow read, write: if false; // Cloud Functions에서만 접근하도록 제한
    }
    
    // ==================== 기타 컬렉션 ====================
    // rooms, invitations, joinRequests 등은 기존 Realtime Database 유지 또는 별도 규칙 필요
    
  }
}

